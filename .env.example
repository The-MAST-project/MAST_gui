# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,mast-wis-control

# MAST Configuration
MAST_SITE=wis
MAST_COMMON_PATH=/path/to/MAST_common
MAST_CONFIG_SOURCE=

# Social Auth (configure if using)
