# SOCIALACCOUNT_PROVIDERS_GOOGLE_CLIENT_ID=
# SOCIALACCOUNT_PROVIDERS_GOOGLE_SECRET=

# Facebook
# SOCIALACCOUNT_PROVIDERS_FACEBOOK_CLIENT_ID=
# SOCIALACCOUNT_PROVIDERS_FACEBOOK_SECRET=

# Apple
# SOCIALACCOUNT_PROVIDERS_APPLE_CLIENT_ID=
